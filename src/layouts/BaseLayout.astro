---
import Cursor from '../components/Cursor.astro';
export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Sean Millard — Web Developer',
  description = 'Web developer building modern websites and web applications. Based in Melbourne, Australia.',
  image = '/logo-sm.svg',
} = Astro.props;

const GA_MEASUREMENT_ID = 'G-PB0Z7X9EK2';
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.toString();
const socialImageUrl = Astro.site
  ? new URL(image, Astro.site).toString()
  : new URL(image, Astro.url).toString();
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content="Sean Millard portfolio preview" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Theme: prevent flash of wrong theme -->
    <script is:inline>
      (function(){
        const t = localStorage.getItem('theme');
        if (t && t !== 'default') document.documentElement.setAttribute('data-theme', t);
      })();
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Google tag (gtag.js) -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function gtag() {
        window.dataLayer.push(arguments);
      };
      window.gtag('js', new Date());
      window.gtag('config', 'G-PB0Z7X9EK2');
    </script>
  </head>

  <body class="bg-black text-white antialiased overflow-x-hidden">
    <!-- Pointer glow -->
    <div
      id="spotlight"
      class="pointer-events-none fixed inset-0 z-30"
      style="transition: background 0.4s ease, opacity 0.3s ease;"
    ></div>

    <slot />
    <Cursor />

    <!-- Scroll reveal script -->
    <script>
      const spotlight = document.getElementById('spotlight');
      if (spotlight instanceof HTMLElement) {
        let targetX = window.innerWidth / 2;
        let targetY = window.innerHeight / 2;
        let currentX = targetX;
        let currentY = targetY;

        const updateTarget = (x, y) => {
          targetX = x;
          targetY = y;
        };

        function spotlightDefault() {
          return document.documentElement.getAttribute('data-theme') === 'light'
            ? { r: 26, g: 26, b: 26 }
            : { r: 255, g: 255, b: 255 };
        }

        let { r: accentR, g: accentG, b: accentB } = spotlightDefault();

      function buildGradient(r: number, g: number, b: number) {
        return `
          radial-gradient(160px circle at var(--spotlight-x, 50vw) var(--spotlight-y, 35vh), rgba(${r},${g},${b},0.20), transparent 100%),
          radial-gradient(580px circle at var(--spotlight-x, 50vw) var(--spotlight-y, 35vh), rgba(${r},${g},${b},0.07) 0%, rgba(${r},${g},${b},0.03) 50%, transparent 75%)
        `;
      }

      spotlight.style.background = buildGradient(accentR, accentG, accentB);

      window.addEventListener('cursorcolor', (e: Event) => {
        const { r, g, b } = (e as CustomEvent).detail ?? spotlightDefault();
        accentR = r; accentG = g; accentB = b;
        spotlight.style.background = buildGradient(r, g, b);
      });

      window.addEventListener('themechange', () => {
        const def = spotlightDefault();
        accentR = def.r; accentG = def.g; accentB = def.b;
        spotlight.style.background = buildGradient(def.r, def.g, def.b);
      });

      const animateSpotlight = () => {
          currentX += (targetX - currentX) * 0.10;
          currentY += (targetY - currentY) * 0.10;
          spotlight.style.setProperty('--spotlight-x', `${currentX}px`);
          spotlight.style.setProperty('--spotlight-y', `${currentY}px`);
          requestAnimationFrame(animateSpotlight);
        };

        document.addEventListener('pointermove', (event) => {
          updateTarget(event.clientX, event.clientY);
        });

        animateSpotlight();
      }

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches && spotlight instanceof HTMLElement) {
        spotlight.style.opacity = '0';
      }

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((element) => {
        revealObserver.observe(element);
      });

    </script>
  </body>
</html>
