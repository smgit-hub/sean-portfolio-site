---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Thank You — Sean Millard"
  description="Thanks for your message. I'll get back to you soon."
>
  <Navigation />
  <main class="min-h-[70vh] flex items-center justify-center px-6">
    <section class="max-w-xl w-full glass rounded-2xl p-8 border border-white/5 text-center reveal visible">
      <p class="font-mono text-neon-green/70 text-xs tracking-widest uppercase mb-3">Message Sent</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">
        Thank you
      </h1>
      <p class="text-white/55 leading-relaxed mb-8">
        Your message has been received. I will get back to you as soon as possible.
      </p>
      <a
        href="/#contact"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-neon-green text-black font-semibold text-sm transition-all duration-300 hover:shadow-glow-green hover:scale-[1.02]"
      >
        Back to site
      </a>
    </section>
  </main>
  <Footer />
</BaseLayout>
