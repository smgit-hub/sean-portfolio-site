---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<BaseLayout
  title="Thank You — Sean Millard"
  description="Thanks for your message. I'll get back to you soon."
>
  <Navigation />
  <main class="min-h-[70vh] flex items-center justify-center px-6">
    <section class="max-w-2xl w-full rounded-lg p-8 border text-center" style="border-color: var(--border); background-color: var(--bg);">
      <p class="text-xs font-mono uppercase tracking-widest mb-3" style="color: var(--accent);">Message Sent</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4" style="color: var(--text);">
        Thank you
      </h1>
      <p class="text-lg leading-relaxed mb-8" style="color: var(--text-muted);">
        Your message has been received. I'll get back to you as soon as possible.
      </p>
      <a
        href="/#contact"
        class="inline-block px-6 py-3 border font-medium rounded transition-colors"
        style="border-color: var(--accent); color: var(--accent);"
        onmouseover="this.style.backgroundColor='rgba(34, 197, 94, 0.1)'"
        onmouseout="this.style.backgroundColor='transparent'"
      >
        Back to site
      </a>
    </section>
  </main>
  <Footer />
</BaseLayout>
