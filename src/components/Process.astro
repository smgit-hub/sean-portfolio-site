---
const steps = [
  {
    number: '01',
    title: 'Understand the brief',
    body: "Every project starts with clarity. I take time to understand the goal, the audience, and the constraints before writing a single line of code. Good questions save hours later.",
  },
  {
    number: '02',
    title: 'Design with intent',
    body: "Whether working from a client brief or designing independently, I map out structure, layout, and interaction before writing production code. Low-fidelity first, detail second.",
  },
  {
    number: '03',
    title: 'Build clean, fast, and secure',
    body: "Once direction is clear, I move quickly with a working prototype — whether that's a marketing site or a full-stack app — then refine with clean code, strong performance, and security in mind.",
  },
  {
    number: '04',
    title: 'APIs, data, and integration',
    body: "From connecting a CMS (like Sanity or WordPress) to consuming live REST APIs, I integrate external services and build interfaces around real, dynamic content.",
  },
  {
    number: '05',
    title: 'Deploy and iterate',
    body: "I deploy to Vercel or Netlify, manage domains and DNS, and treat the live environment as part of the workflow — not the finish line. Apps and sites get reviewed, refined, and improved after launch.",
  },
  {
    number: '06',
    title: 'Review, test, and improve',
    body: "I treat each release as a checkpoint, not a finish line — validating assumptions, tightening edge cases, and improving what can be made clearer, faster, or more reliable.",
  },
];
---

<section id="process" class="section-padding relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Label -->
    <div class="flex items-center gap-3 mb-4 reveal">
      <span class="section-label font-mono text-xs tracking-widest uppercase">Process</span>
      <span class="section-label-line flex-1 max-w-[60px] h-px"></span>
    </div>

    <h2 class="text-3xl font-bold mb-4 reveal" style="color: var(--text);">
      How I <span style="color: var(--accent);">work</span>
    </h2>
    <p class="text-lg max-w-xl mb-14 reveal reveal-delay-1" style="color: var(--text-muted);">
      A pragmatic, iterative approach focused on real outcomes, not process theatre.
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {steps.map((step, i) => {
        const delayClass = `reveal-delay-${Math.min(i + 1, 5)}`;
        return (
          <div class={`reveal ${delayClass} group rounded-lg p-6 border transition-all`} style="border-color: var(--border); background-color: var(--bg);">
            <div class="flex items-center justify-between mb-5">
              <span
                class="font-mono font-bold text-3xl leading-none opacity-40 group-hover:opacity-100 transition-opacity duration-300"
                style="color: var(--accent);"
              >
                {step.number}
              </span>
              <div
                class="w-8 h-8 rounded-full border flex items-center justify-center opacity-60 group-hover:opacity-100 transition-all duration-300"
                style="border-color: var(--accent);"
              >
                <span class="w-1.5 h-1.5 rounded-full" style="background: var(--accent);"></span>
              </div>
            </div>
            <h3 class="font-semibold text-base mb-2 transition-colors" style="color: var(--text);">
              {step.title}
            </h3>
            <p class="text-sm leading-relaxed transition-colors duration-300" style="color: var(--text-muted);">
              {step.body}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</section>
