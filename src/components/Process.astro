---
const steps = [
  {
    number: '01',
    title:  'Understand the brief',
    body:   "Every project starts with clarity. I take time to understand the goal, the audience, and the constraints before writing a single line of code. Good questions save hours later.",
    color:  'green',
  },
  {
    number: '02',
    title:  'Design with intent',
    body:   "Whether working from a client brief or designing independently, I think through structure, layout, and interaction before touching a text editor. Low-fidelity first, detail second.",
    color:  'blue',
  },
  {
    number: '03',
    title:  'Build clean, fast, and secure',
    body:   "Once the direction is determined, I like to build prototypes fast and find what improvements can be made. From there I refine with clean code, performance, and security in mind.",
    color:  'green',
  },
  {
    number: '04',
    title:  'APIs, data, and integration',
    body:   "From connecting a CMS like Sanity or WordPress to fetching live data via REST APIs, I'm comfortable wiring up external services and building interfaces around real, dynamic content.",
    color:  'blue',
  },
  {
    number: '05',
    title:  'Deploy and iterate',
    body:   "I deploy to Vercel or Netlify, manage domains and DNS, and treat the live environment as part of the workflow — not the finish line. Sites get reviewed, refined, and improved after launch.",
    color:  'red',
  },
  {
    number: '06',
    title:  'AI as a workflow layer',
    body:   "I use Claude Code, ChatGPT, and Codex as genuine tools — for exploring unfamiliar patterns, accelerating debugging, and stress-testing ideas. The code I ship is understood and intentional.",
    color:  'red',
  },
];

const colorMap: Record<string, string> = {
  green: '#00ff88',
  blue:  '#00b4ff',
  red:   '#ff3366',
};
---

<section id="process" class="section-padding relative overflow-hidden">
  <div
    class="absolute bottom-0 right-0 w-[500px] h-[400px] pointer-events-none"
    style="background: radial-gradient(ellipse at 100% 100%, rgba(255,51,102,0.04), transparent 60%);"
  ></div>

  <div class="max-w-7xl mx-auto px-6">
    <!-- Label -->
    <div class="flex items-center gap-3 mb-4 reveal">
      <span class="font-mono text-neon-green/60 text-xs tracking-widest uppercase">05 / Process</span>
      <span class="flex-1 max-w-[60px] h-px bg-neon-green/20"></span>
    </div>

    <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 reveal">
      How I <span class="gradient-text-green-blue">work</span>
    </h2>
    <p class="text-white/45 max-w-xl mb-14 reveal reveal-delay-1">
      A pragmatic, iterative approach — designed to produce good outcomes rather than impressive-sounding processes.
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {steps.map((step, i) => {
        const col = colorMap[step.color];
        const delayClass = `reveal-delay-${Math.min(i + 1, 5)}`;
        return (
          <div class={`reveal ${delayClass} group glass glass-hover rounded-2xl p-6 border border-white/5`}>
            <div class="flex items-center justify-between mb-5">
              <span
                class="font-mono font-bold text-3xl leading-none opacity-20 group-hover:opacity-50 transition-opacity duration-300"
                style={`color: ${col};`}
              >
                {step.number}
              </span>
              <div
                class="w-8 h-8 rounded-full border flex items-center justify-center opacity-40 group-hover:opacity-80 transition-all duration-300"
                style={`border-color: ${col}; box-shadow: 0 0 10px ${col}40;`}
              >
                <span class="w-1.5 h-1.5 rounded-full" style={`background: ${col};`}></span>
              </div>
            </div>
            <h3 class="font-display font-semibold text-base text-white mb-2 group-hover:text-white transition-colors">
              {step.title}
            </h3>
            <p class="text-sm text-white/40 leading-relaxed group-hover:text-white/55 transition-colors duration-300">
              {step.body}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</section>
