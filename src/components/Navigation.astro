---
const links = [
  { href: '#plans', label: 'Plans' },
  { href: '#projects', label: 'Work' },
  { href: '#about', label: 'About' },
  { href: '#process', label: 'Process' },
  { href: '#contact', label: 'Contact' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-transparent bg-transparent transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="#"
      class="font-display font-bold text-lg tracking-tight group flex items-center"
    >
      <img
        src="/logo-sm.svg"
        alt="SM logo"
        width="34"
        height="34"
        class="h-9 w-9 transition-transform duration-300 group-hover:scale-105"
      />
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link text-sm font-medium relative group"
          >
            {link.label}
            <span class="nav-link-underline absolute -bottom-0.5 left-0 w-0 h-px group-hover:w-full transition-all duration-300"></span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Theme toggle -->
    <button id="theme-toggle" aria-label="Switch colour theme" class="hidden md:flex items-center gap-1.5 p-2 rounded-full border border-white/10 hover:border-white/20 transition-colors duration-300">
      <span class="theme-dot w-2 h-2 rounded-full" style="background: var(--c1);"></span>
      <span class="theme-dot w-2 h-2 rounded-full" style="background: var(--c2);"></span>
      <span class="theme-dot w-2 h-2 rounded-full" style="background: var(--c3);"></span>
    </button>

    <!-- CTA -->
    <a
      href="#contact"
      class="nav-cta hidden md:inline-flex items-center gap-2 text-sm font-medium px-4 py-1.5 rounded-full border transition-all duration-300"
    >
      Let's work
    </a>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden text-white/60 hover:text-white transition-colors p-2"
      aria-label="Toggle menu"
    >
      <svg id="icon-open" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="hidden">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-black/95 backdrop-blur-xl border-t border-white/5 px-6 pb-6 pt-4"
  >
    <ul class="flex flex-col gap-4">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link nav-link text-base font-medium block"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a
      href="#contact"
      class="mobile-link nav-cta mt-6 inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-full border"
    >
      Let's work
    </a>
    <button id="theme-toggle-mobile" aria-label="Switch colour theme" class="mt-4 flex items-center gap-2 p-2 rounded-full border border-white/10 hover:border-white/20 transition-colors duration-300 w-fit">
      <span class="theme-dot w-2 h-2 rounded-full" style="background: var(--c1);"></span>
      <span class="theme-dot w-2 h-2 rounded-full" style="background: var(--c2);"></span>
      <span class="theme-dot w-2 h-2 rounded-full" style="background: var(--c3);"></span>
    </button>
  </div>
</nav>

<script>
  const navToggleButton = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('icon-open');
  const closeIcon = document.getElementById('icon-close');
  const mainNav = document.getElementById('main-nav');

  const setMobileMenuOpen = (isOpen) => {
    mobileMenu?.classList.toggle('hidden', !isOpen);
    openIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  };

  const updateNavState = () => {
    if (!(mainNav instanceof HTMLElement)) return;
    const isScrolled = window.scrollY > 12;
    mainNav.classList.toggle('bg-black/90', isScrolled);
    mainNav.classList.toggle('backdrop-blur-xl', isScrolled);
    mainNav.classList.toggle('border-white/10', isScrolled);
    mainNav.classList.toggle('shadow-[0_8px_24px_rgba(0,0,0,0.35)]', isScrolled);
    mainNav.classList.toggle('border-transparent', !isScrolled);
  };

  navToggleButton?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden');
    setMobileMenuOpen(Boolean(isOpen));
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      setMobileMenuOpen(false);
    });
  });

  setMobileMenuOpen(false);
  updateNavState();
  window.addEventListener('scroll', updateNavState, { passive: true });

  // Theme switcher
  const themes = ['default', 'light'] as const;
  type Theme = typeof themes[number];

  function applyNavLightStyles(isLight: boolean) {
    // Hamburger: swap hover:text-white ↔ hover:text-black
    const hamburger = document.getElementById('nav-toggle');
    if (hamburger) {
      hamburger.classList.toggle('hover:text-white', !isLight);
      hamburger.classList.toggle('hover:text-black', isLight);
    }
    // Nav links: at-rest opacity
    document.querySelectorAll<HTMLElement>('nav ul a, .mobile-link').forEach(el => {
      el.classList.toggle('text-white\\/60', !isLight);
      el.classList.toggle('text-white\\/70', !isLight);
      el.classList.toggle('text-black\\/55', isLight);
    });
    // CTA button: remove glow hover in light, keep border hover
    const ctas = document.querySelectorAll<HTMLElement>('nav a.rounded-full');
    ctas.forEach(el => {
      el.classList.toggle('hover:shadow-glow-sm-green', !isLight);
    });
  }

  function applyTheme(theme: Theme) {
    if (theme === 'default') {
      document.documentElement.removeAttribute('data-theme');
    } else {
      document.documentElement.setAttribute('data-theme', theme);
    }
    localStorage.setItem('theme', theme);
    applyNavLightStyles(theme === 'light');
    window.dispatchEvent(new CustomEvent('themechange', { detail: { theme } }));
  }

  // Apply on page load
  applyNavLightStyles(getCurrentTheme() === 'light');

  function getCurrentTheme(): Theme {
    const stored = localStorage.getItem('theme') as Theme | null;
    return stored && themes.includes(stored) ? stored : 'default';
  }

  function cycleTheme() {
    const current = getCurrentTheme();
    const nextIndex = (themes.indexOf(current) + 1) % themes.length;
    applyTheme(themes[nextIndex]);
  }

  document.getElementById('theme-toggle')?.addEventListener('click', cycleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', cycleTheme);
</script>

<style is:global>
  /* ── Nav link base colours (no Tailwind hover utilities involved) ── */
  .nav-link { color: rgba(255, 255, 255, 0.6); }
  .nav-link:hover { color: var(--c1); }
  .nav-link-underline { background: var(--c1); }

  [data-theme="light"] .nav-link { color: rgba(26, 26, 26, 0.6); }
  [data-theme="light"] .nav-link:hover { color: var(--c1); }
  [data-theme="light"] .nav-link-underline { background: var(--c1); }

  /* ── CTA button (no Tailwind hover utilities) ── */
  .nav-cta {
    color: var(--c1);
    border-color: rgb(var(--c1-rgb) / 0.3);
  }
  .nav-cta:hover {
    border-color: var(--c1);
    box-shadow: 0 0 8px rgb(var(--c1-rgb) / 0.5);
  }

  [data-theme="light"] .nav-cta:hover {
    box-shadow: 0 1px 6px rgb(var(--c1-rgb) / 0.2);
    background: rgb(var(--c1-rgb) / 0.07);
  }

  /* ── Other light theme nav fixes ── */
  [data-theme="light"] #nav-toggle { color: rgba(26, 26, 26, 0.6); }
  [data-theme="light"] #nav-toggle:hover { color: rgba(26, 26, 26, 0.9); }

  [data-theme="light"] #main-nav a.rounded-full:hover {
    box-shadow: 0 1px 6px rgba(45, 122, 79, 0.18);
    background: rgba(45, 122, 79, 0.07);
  }
  [data-theme="light"] #theme-toggle:hover,
  [data-theme="light"] #theme-toggle-mobile:hover {
    border-color: rgba(0, 0, 0, 0.25);
  }
</style>
