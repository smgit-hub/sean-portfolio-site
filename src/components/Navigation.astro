---
const links = [
  { href: '#stack', label: 'Stack' },
  { href: '#projects', label: 'Work' },
  { href: '#about', label: 'About' },
  { href: '#process', label: 'Process' },
  { href: '#contact', label: 'Contact' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-transparent bg-transparent transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between relative">
    <!-- Left: Logo -->
    <a
      href="#"
      class="font-display font-bold text-lg tracking-tight group flex items-center"
    >
      <img
        src="/logo-sm.svg"
        alt="SM logo"
        width="34"
        height="34"
        class="h-9 w-9 transition-transform duration-300 group-hover:scale-105"
      />
    </a>

    <!-- Center: Desktop links (truly centered via absolute) -->
    <ul class="hidden md:flex items-center gap-8 absolute left-1/2 -translate-x-1/2">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link text-sm font-medium relative group"
          >
            {link.label}
            <span class="nav-link-underline absolute -bottom-0.5 left-0 w-0 h-px group-hover:w-full transition-all duration-300"></span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Right: CTA + mobile hamburger -->
    <div class="flex items-center gap-3">
      <!-- CTA -->
      <a
        href="#contact"
        class="nav-cta hidden md:inline-flex items-center gap-2 text-sm font-medium px-4 py-1.5 rounded-full border transition-all duration-300"
      >
        Let's work
      </a>

      <!-- Mobile hamburger -->
      <button
        id="nav-toggle"
        class="md:hidden text-white/60 hover:text-white transition-colors p-2"
        aria-label="Toggle menu"
      >
      <svg id="icon-open" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="hidden">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-black/95 backdrop-blur-xl border-t border-white/5 px-6 pb-6 pt-4"
  >
    <ul class="flex flex-col gap-4">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link nav-link text-base font-medium block"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a
      href="#contact"
      class="mobile-link nav-cta mt-6 inline-flex items-center gap-2 text-sm font-medium px-4 py-2 rounded-full border"
    >
      Let's work
    </a>
  </div>
</nav>

<script>
  const navToggleButton = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('icon-open');
  const closeIcon = document.getElementById('icon-close');
  const mainNav = document.getElementById('main-nav');

  const setMobileMenuOpen = (isOpen) => {
    mobileMenu?.classList.toggle('hidden', !isOpen);
    openIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  };

  const updateNavState = () => {
    if (!(mainNav instanceof HTMLElement)) return;
    const isScrolled = window.scrollY > 12;
    mainNav.classList.toggle('bg-black/90', isScrolled);
    mainNav.classList.toggle('backdrop-blur-xl', isScrolled);
    mainNav.classList.toggle('border-white/10', isScrolled);
    mainNav.classList.toggle('shadow-[0_8px_24px_rgba(0,0,0,0.35)]', isScrolled);
    mainNav.classList.toggle('border-transparent', !isScrolled);
  };

  navToggleButton?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden');
    setMobileMenuOpen(Boolean(isOpen));
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      setMobileMenuOpen(false);
    });
  });

  setMobileMenuOpen(false);
  updateNavState();
  window.addEventListener('scroll', updateNavState, { passive: true });
</script>

<style is:global>
  /* ── Nav link base colours ── */
  .nav-link { color: rgba(255, 255, 255, 0.6); }
  .nav-link:hover { color: var(--accent); }
  .nav-link-underline { background: var(--accent); }

  /* ── CTA button ── */
  .nav-cta {
    color: var(--accent);
    border-color: rgb(var(--accent-rgb) / 0.3);
  }
  .nav-cta:hover {
    border-color: var(--accent);
    background: rgb(var(--accent-rgb) / 0.08);
  }
</style>
