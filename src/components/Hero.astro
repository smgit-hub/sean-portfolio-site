---
const techTags = ['Astro', 'React', 'Next.js', 'Tailwind', 'Figma', 'Custom WordPress'];
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden bg-black"
>
  <!-- Background grid -->
  <div class="absolute inset-0 bg-grid opacity-40 pointer-events-none"></div>

  <!-- Ambient glow blobs -->
  <div
    class="hero-blob absolute top-[-20%] left-[-10%] w-[600px] h-[600px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgb(var(--c1-rgb) / 0.07) 0%, transparent 70%);"
  ></div>
  <div
    class="hero-blob absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgb(var(--c2-rgb) / 0.07) 0%, transparent 70%);"
  ></div>
  <div
    class="hero-blob absolute top-[30%] right-[20%] w-[300px] h-[300px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgb(var(--c3-rgb) / 0.04) 0%, transparent 70%);"
  ></div>

<!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 pt-24 pb-8 text-center">

    <!-- Location label -->
    <p class="font-mono text-xs tracking-widest uppercase mb-10 animate-fade-up" style="animation-delay: 0.08s;">
      <span class="name-letter" style="animation-delay:0.0s;">W</span><span class="name-letter" style="animation-delay:0.1s;">e</span><span class="name-letter" style="animation-delay:0.2s;">b</span><span class="name-letter" style="animation-delay:0.3s;"> </span><span class="name-letter" style="animation-delay:0.4s;">d</span><span class="name-letter" style="animation-delay:0.5s;">e</span><span class="name-letter" style="animation-delay:0.6s;">v</span><span class="name-letter" style="animation-delay:0.7s;">e</span><span class="name-letter" style="animation-delay:0.8s;">l</span><span class="name-letter" style="animation-delay:0.9s;">o</span><span class="name-letter" style="animation-delay:1.0s;">p</span><span class="name-letter" style="animation-delay:1.1s;">m</span><span class="name-letter" style="animation-delay:1.2s;">e</span><span class="name-letter" style="animation-delay:1.3s;">n</span><span class="name-letter" style="animation-delay:1.4s;">t</span><span class="name-letter" style="animation-delay:1.5s;"> </span><span class="name-letter" style="animation-delay:1.6s;">·</span><span class="name-letter" style="animation-delay:1.7s;"> </span><span class="name-letter" style="animation-delay:1.8s;">M</span><span class="name-letter" style="animation-delay:1.9s;">e</span><span class="name-letter" style="animation-delay:2.0s;">l</span><span class="name-letter" style="animation-delay:2.1s;">b</span><span class="name-letter" style="animation-delay:2.2s;">o</span><span class="name-letter" style="animation-delay:2.3s;">u</span><span class="name-letter" style="animation-delay:2.4s;">r</span><span class="name-letter" style="animation-delay:2.5s;">n</span><span class="name-letter" style="animation-delay:2.6s;">e</span><span class="name-letter" style="animation-delay:2.7s;">,</span><span class="name-letter" style="animation-delay:2.8s;"> </span><span class="name-letter" style="animation-delay:2.9s;">A</span><span class="name-letter" style="animation-delay:3.0s;">U</span>
    </p>

    <!-- Headline -->
    <h1 class="font-display font-bold leading-none mb-10 animate-fade-up" style="font-size: clamp(2.8rem, 9vw, 6rem); animation-delay: 0.15s;">
      <span class="block text-white">A website that works.</span>
      <span class="block gradient-text">No excuses.</span>
    </h1>

    <!-- CTAs -->
    <div class="flex flex-wrap items-center justify-center gap-4 mb-10 animate-fade-up" style="animation-delay: 0.28s;">
      <a
        href="#plans"
        class="hero-cta-primary group relative inline-flex items-center gap-2 px-7 py-3 rounded-full font-semibold text-sm transition-all duration-300 hover:scale-105"
      >
        See plans
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="transition-transform duration-300 group-hover:translate-y-0.5">
          <path d="M12 5v14M5 12l7 7 7-7"/>
        </svg>
      </a>
      <a
        href="#projects"
        class="hero-cta-secondary group inline-flex items-center gap-2 px-7 py-3 rounded-full border font-medium text-sm transition-all duration-300"
      >
        View work
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="transition-transform duration-300 group-hover:translate-x-1">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Tech tags -->
    <div class="flex flex-wrap items-center justify-center gap-3 mb-10 animate-fade-up" style="animation-delay: 0.4s;">
      {techTags.map((tech) => (
        <span class="tech-tag">{tech}</span>
      ))}
    </div>

    <!-- Name -->
    <p class="font-mono text-xs tracking-widest animate-fade-up name-flicker" style="animation-delay: 0.5s;">
      <span class="name-letter">S</span><span class="name-letter">e</span><span class="name-letter">a</span><span class="name-letter">n</span><span class="name-letter"> </span><span class="name-letter">M</span><span class="name-letter">i</span><span class="name-letter">l</span><span class="name-letter">l</span><span class="name-letter">a</span><span class="name-letter">r</span><span class="name-letter">d</span>
    </p>
  </div>

</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    opacity: 0;
    animation: fadeUp 0.7s ease forwards;
  }

  @keyframes letterCycle {
    0%, 100% { color: rgba(255,255,255,0.2); }
    33%       { color: #00ff88; text-shadow: 0 0 8px rgba(0,255,136,0.8); }
    66%       { color: #00b4ff; text-shadow: 0 0 8px rgba(0,180,255,0.8); }
  }

  .name-letter {
    display: inline-block;
    color: rgba(255,255,255,0.2);
    animation: letterCycle 4s ease-in-out infinite;
  }

  .name-letter:nth-child(1)  { animation-delay: 0.0s; }
  .name-letter:nth-child(2)  { animation-delay: 0.15s; }
  .name-letter:nth-child(3)  { animation-delay: 0.3s; }
  .name-letter:nth-child(4)  { animation-delay: 0.45s; }
  .name-letter:nth-child(5)  { animation-delay: 0.6s; }
  .name-letter:nth-child(6)  { animation-delay: 0.75s; }
  .name-letter:nth-child(7)  { animation-delay: 0.9s; }
  .name-letter:nth-child(8)  { animation-delay: 1.05s; }
  .name-letter:nth-child(9)  { animation-delay: 1.2s; }
  .name-letter:nth-child(10) { animation-delay: 1.35s; }
  .name-letter:nth-child(11) { animation-delay: 1.5s; }
  .name-letter:nth-child(12) { animation-delay: 1.65s; }

  /* ── Hero CTAs — theme-aware, no Tailwind hover utilities ── */
  .hero-cta-primary {
    background: var(--c1);
    color: #000;
    box-shadow: none;
  }
  .hero-cta-primary:hover {
    box-shadow: 0 0 20px rgb(var(--c1-rgb) / 0.4);
    ring: 2px solid rgba(255,255,255,0.5);
  }

  .hero-cta-secondary {
    border-color: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.7);
  }
  .hero-cta-secondary:hover {
    border-color: rgb(var(--c2-rgb) / 0.4);
    color: var(--c2);
    box-shadow: 0 0 20px rgb(var(--c2-rgb) / 0.25);
  }

  :global([data-theme="light"]) .hero-cta-primary {
    color: #fff;
    box-shadow: none;
  }
  :global([data-theme="light"]) .hero-cta-primary:hover {
    box-shadow: 0 2px 12px rgb(var(--c1-rgb) / 0.3);
  }

  :global([data-theme="light"]) .hero-cta-secondary {
    border-color: rgba(26,26,26,0.15);
    color: rgba(26,26,26,0.6);
  }
  :global([data-theme="light"]) .hero-cta-secondary:hover {
    border-color: rgb(var(--c2-rgb) / 0.5);
    color: var(--c2);
    box-shadow: 0 2px 10px rgb(var(--c2-rgb) / 0.15);
  }
</style>
