---
const groups = [
  {
    label: 'Frontend',
    blurb: 'What users touch',
    tools: ['React', 'Next.js', 'Astro', 'TypeScript', 'Tailwind CSS'],
  },
  {
    label: 'Backend & data',
    blurb: 'Where the logic lives',
    tools: ['Supabase', 'PHP', 'REST APIs'],
  },
  {
    label: 'CMS & content',
    blurb: 'Where content lives',
    tools: ['WordPress', 'Sanity', 'Headless CMS'],
  },
  {
    label: 'Workflow & design',
    blurb: 'How it gets shipped',
    tools: ['Figma', 'Vercel', 'Netlify', 'Git'],
  },
];
---

<section id="stack" class="section-padding relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Label -->
    <div class="flex items-center gap-3 mb-4 reveal">
      <span class="section-label font-mono text-xs tracking-widest uppercase">Stack</span>
      <span class="section-label-line flex-1 max-w-[60px] h-px"></span>
    </div>

    <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 reveal">
      Tools & <span style="color: var(--accent);">technologies</span>
    </h2>
    <p class="text-white/45 max-w-xl mb-12 reveal reveal-delay-1">
      What I reach for day to day, picked to fit the project rather than out of habit.
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {groups.map((group, i) => (
        <div class={`reveal reveal-delay-${i + 1} panel rounded-2xl p-6 border`} style="border-color: rgba(255,255,255,0.08);">
          <p class="font-display font-semibold text-base text-white mb-1">{group.label}</p>
          <p class="text-xs text-white/35 font-mono mb-5">{group.blurb}</p>
          <div class="flex flex-wrap gap-2">
            {group.tools.map((tool) => (
              <span class="tech-tag">{tool}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
