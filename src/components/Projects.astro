---
const projects = [
  {
    title:   'Level Design Australia',
    type:    'Custom Timber Furniture Website',
    status:  'live',
    summary: 'A professional website for a custom timber furniture business. Built with a focus on clean presentation, clear service communication, and strong SEO foundations.',
    image: '/images/projects/pages/level-1.jpg',
    stack:   ['Astro', 'Tailwind CSS', 'JavaScript'],
    url:     'https://leveldesign.com.au/',
    accent:  'blue',
  },
  {
    title:   'Worth a Watch',
    type:    'Web Application',
    status:  'live',
    summary: 'A movie and TV series discovery app utilising OMDb and Watchmode APIs, plus OpenAI to generate tailored watch recommendations from qualifying user questions. Search any title and get details, ratings, cast, and where to watch — all rendered dynamically without a page reload.',
    image: '/images/projects/pages/worth-1.jpg',
    stack:   ['Next.js', 'React', 'Tailwind CSS'],
    url:     'https://worth-a-watch.netlify.app/',
    accent:  'green',
  },
  {
    title:   'Andrea Flower Shop',
    type:    'Multilingual Client Website',
    status:  'live',
    summary: 'A multilingual website for a flower shop focused on lead generation and strong SEO foundations, helping attract local customers and convert visits into enquiries.',
    image: '/images/projects/pages/andrea-1.jpg',
    stack:   ['Astro', 'Tailwind CSS', 'JavaScript'],
    url:     'https://kvetinarstvoandrea.com/en/',
    accent:  'green',
  },
  {
    title:   'Cosy Cowes Getaway',
    type:    'Accomodation Website',
    status:  'live',
    summary: 'A holiday rental website for a property on Phillip Island. Handles property presentation, availability information, and guest enquiries.',
    image: '/images/projects/pages/cosy-1.jpg',
    stack:   ['Astro', 'Tailwind CSS', 'JavaScript'],
    url:     'https://cosycowesgetaway.com/',
    accent:  'red',
  },
  {
    title:   'Automotive Sales Resources & Training Hub',
    type:    'Interactive Web App',
    status:  'in-progress',
    summary: 'A dedicated platform for automotive sales teams to access all resource videos and complete structured training modules with embedded videos and knowledge-check questions.',
    image: '/images/projects/pages/auto-sales-1.jpg',
    stack:   ['React', 'JavaScript', 'Tailwind CSS'],
    url:     null,
    accent:  'blue',
  },
  {
    title:   'Traffic Management Site',
    type:    'Website + Dashboard',
    status:  'in-progress',
    summary: 'A traffic signal fault reporting platform with an operations dashboard to triage issues, assign contractors, and track repairs through to verified completion.',
    image: '/images/projects/pages/traffic-1.jpg',
    stack:   ['Next.js', 'Tailwind CSS', 'Sanity CMS'],
    url:     null,
    accent:  'red',
  },
];

const accentMap: Record<string, { border: string; tag: string; glow: string; dot: string }> = {
  green: {
    border: 'rgba(0,255,136,0.2)',
    tag:    'green',
    glow:   'rgba(0,255,136,0.1)',
    dot:    '#00ff88',
  },
  blue: {
    border: 'rgba(0,180,255,0.2)',
    tag:    'blue',
    glow:   'rgba(0,180,255,0.1)',
    dot:    '#00b4ff',
  },
  red: {
    border: 'rgba(255,51,102,0.2)',
    tag:    'red',
    glow:   'rgba(255,51,102,0.08)',
    dot:    '#ff3366',
  },
};

const accentOrder = ['green', 'blue', 'red'] as const;
---

<section id="projects" class="section-padding relative overflow-hidden">
  <div
    class="absolute top-1/4 right-0 w-[400px] h-[400px] pointer-events-none"
    style="background: radial-gradient(circle at 100% 50%, rgba(0,180,255,0.05), transparent 60%);"
  ></div>

  <div class="max-w-7xl mx-auto px-6">
    <!-- Label -->
    <div class="flex items-center gap-3 mb-4 reveal">
      <span class="font-mono text-neon-green/60 text-xs tracking-widest uppercase">03 / Projects</span>
      <span class="flex-1 max-w-[60px] h-px bg-neon-green/20"></span>
    </div>

    <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 reveal">
      Work I've <span class="gradient-text-green-blue">shipped</span>
    </h2>
    <p class="text-white/45 max-w-xl mb-14 reveal reveal-delay-1">
      A mix of live client sites, personal apps, and projects currently in development.
    </p>

    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-5">
      {projects.map((project, i) => {
        const a = accentMap[accentOrder[i % accentOrder.length]];
        const delayClass = `reveal-delay-${Math.min(i + 1, 5)}`;
        return (
          <article
            class={`project-card reveal ${delayClass} group relative glass rounded-2xl p-6 flex flex-col border transition-all duration-400 cursor-default`}
            style={`--project-border: ${a.border}; border-color: rgba(255,255,255,0.06);`}
          >
            <!-- Hover glow overlay -->
            <div
              class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
              style={`background: radial-gradient(ellipse at 50% 0%, ${a.glow}, transparent 70%);`}
            ></div>

            <!-- Project thumbnail -->
            <div class="project-thumb mb-5" style={`--shot-color: ${a.dot};`}>
              {project.image ? (
                <img
                  src={project.image}
                  alt={`${project.title} preview`}
                  loading="lazy"
                  class="project-shot-image"
                />
              ) : (
                <div class="project-shot">
                  <span>Coming Soon</span>
                </div>
              )}
            </div>

            <!-- Top row -->
            <div class="flex items-start justify-between mb-4">
              <span
                class="text-xs font-mono px-2.5 py-1 rounded-full border"
                style={`color: ${a.dot}; border-color: ${a.border}; background: ${a.glow};`}
              >
                {project.type}
              </span>
              <span
                class="flex items-center gap-1.5 text-xs font-medium"
                style={`color: ${project.status === 'live' ? '#00ff88' : '#ff3366'};`}
              >
                <span
                  class="w-1.5 h-1.5 rounded-full animate-glow-pulse inline-block"
                  style={`background: ${project.status === 'live' ? '#00ff88' : '#ff3366'};`}
                ></span>
                {project.status === 'live' ? 'Live' : 'In Progress'}
              </span>
            </div>

            <!-- Title -->
            <h3 class="font-display font-semibold text-lg text-white mb-2 group-hover:text-neon-green transition-colors duration-300">
              {project.title}
            </h3>

            <!-- Summary -->
            <p class="text-sm text-white/45 leading-relaxed mb-5 flex-1">
              {project.summary}
            </p>

            <!-- Stack -->
            <div class="flex flex-wrap gap-1.5 mb-5">
              {project.stack.map((tech) => (
                <span class={`tech-tag ${a.tag === 'green' ? '' : a.tag}`}>{tech}</span>
              ))}
            </div>

            <!-- Link -->
            {project.url ? (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-300 group/link"
                style={`color: ${a.dot}; opacity: 0.7;`}
              >
                View live site
                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="transition-transform group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </a>
            ) : (
              <span class="text-sm text-white/20 font-medium">Work in progress</span>
            )}
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .project-card:hover {
    border-color: var(--project-border);
  }

  .project-thumb {
    height: 200px;
    position: relative;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in oklab, var(--shot-color) 26%, white 6%);
    background:
      radial-gradient(100% 70% at 10% 0%, color-mix(in oklab, var(--shot-color) 28%, transparent), transparent 70%),
      linear-gradient(140deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.01) 50%, rgba(0, 0, 0, 0.12)),
      #0b0f0d;
  }

  .project-shot {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .project-shot::before,
  .project-thumb::before {
    content: '';
    position: absolute;
    top: 0.5rem;
    left: 0.55rem;
    width: 2.1rem;
    height: 0.3rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--shot-color) 55%, #ffffff 12%);
    opacity: 0.7;
  }

  .project-shot::after,
  .project-thumb::after {
    content: '';
    position: absolute;
    inset: auto 0.55rem 0.65rem;
    height: 0.34rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
  }

  .project-shot span {
    position: absolute;
    left: 0.58rem;
    bottom: 1.2rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.66);
    text-transform: uppercase;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.65);
    z-index: 2;
  }

  .project-shot-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    transform: scale(0.94);
    transform-origin: top center;
    opacity: 0.9;
  }
</style>
