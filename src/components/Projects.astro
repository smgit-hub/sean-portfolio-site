---
const projects = [
  {
    title: 'StayConnex',
    type: 'SaaS · React · Supabase',
    summary: "Booking and cleaner-coordination tool for short-term rental hosts. Syncs Airbnb, Booking.com calendars, auto-notifies cleaners on changes.",
    url: 'https://stayconnex.com/',
  },
  {
    title: 'Cosy Cowes Getaway',
    type: 'Marketing site · Astro · iCal',
    summary: "Lead-gen marketing site for a holiday rental on Phillip Island. Availability synced from Airbnb at build time, SEO-focused for qualified guests.",
    url: 'https://cosycowesgetaway.com/',
  },
  {
    title: 'Jobwrap',
    type: 'SaaS · React Native · PWA',
    summary: "AI-powered service reports for HVAC technicians. Turns voice notes into polished, branded PDF reports with customer history and scheduling.",
    url: 'https://jobwrap.app/',
  },
];

const screenshotUrl = (url: string) =>
  `https://api.microlink.io/?url=${encodeURIComponent(url)}&screenshot=true&meta=false&embed=screenshot.url&viewport.width=1365&viewport.height=860`;
---

<section id="projects" class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-xs uppercase letter-spacing-wide font-medium text-gray-600 mb-16 reveal">Featured work</h2>

    {projects.map((project, i) => {
      const imageOnLeft = i % 2 === 0;
      return (
        <div class="mb-24 reveal" style={`animation-delay: ${i * 0.1}s`}>
          <div class="grid md:gap-20 items-center" style="grid-template-columns: 1fr 1.1fr;">
            {imageOnLeft ? (
              <>
                <div class="bg-gray-100 h-80 rounded-lg overflow-hidden border border-gray-200">
                  {project.url && (
                    <img src={screenshotUrl(project.url)} alt={project.title} class="w-full h-full object-cover" loading="lazy" />
                  )}
                </div>
                <div>
                  <p class="text-xs uppercase letter-spacing-wide text-gray-500 mb-3 font-medium">{project.type}</p>
                  <h3 class="text-3xl font-bold mb-4">{project.title}</h3>
                  <p class="text-gray-600 leading-relaxed mb-6">{project.summary}</p>
                  {project.url && (
                    <a href={project.url} target="_blank" rel="noopener noreferrer" class="text-green-600 font-medium hover:text-green-700">
                      View live →
                    </a>
                  )}
                </div>
              </>
            ) : (
              <>
                <div>
                  <p class="text-xs uppercase letter-spacing-wide text-gray-500 mb-3 font-medium">{project.type}</p>
                  <h3 class="text-3xl font-bold mb-4">{project.title}</h3>
                  <p class="text-gray-600 leading-relaxed mb-6">{project.summary}</p>
                  {project.url && (
                    <a href={project.url} target="_blank" rel="noopener noreferrer" class="text-green-600 font-medium hover:text-green-700">
                      View live →
                    </a>
                  )}
                </div>
                <div class="bg-gray-100 h-80 rounded-lg overflow-hidden border border-gray-200">
                  {project.url && (
                    <img src={screenshotUrl(project.url)} alt={project.title} class="w-full h-full object-cover" loading="lazy" />
                  )}
                </div>
              </>
            )}
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .letter-spacing-wide {
    letter-spacing: 0.1em;
  }
</style>
