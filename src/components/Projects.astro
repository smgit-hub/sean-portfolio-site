---
const projects = [
  {
    title: 'StayConnex',
    type: 'SaaS · React · TypeScript · Supabase · Stripe · Vercel',
    summary: "Booking and cleaner-coordination tool for short-term rental hosts. Syncs Airbnb, Booking.com calendars, auto-notifies cleaners on changes.",
    url: 'https://stayconnex.com/',
  },
  {
    title: 'Cosy Cowes Getaway',
    type: 'Marketing site · Astro · Tailwind · Stripe · Netlify',
    summary: "Lead-gen marketing site for a holiday rental on Phillip Island. Availability synced from Airbnb at build time, SEO-focused for qualified guests.",
    url: 'https://cosycowesgetaway.com/',
  },
  {
    title: 'JobWrap',
    type: 'SaaS · Next.js · TypeScript · Supabase · Claude AI · Stripe',
    summary: "AI-powered service reports for HVAC technicians. Turns voice notes into polished, branded PDF reports with customer history and scheduling.",
    url: 'https://jobwrap.app/',
  },
  {
    title: 'Andrea Flowers',
    type: 'Marketing site · Astro · Tailwind',
    summary: 'Multilingual florist website with a modern responsive design and auto-generated sitemap.',
    url: 'https://kvetinarstvoandrea.com/',
  },
];

const screenshotUrl = (url: string) =>
  `https://api.microlink.io/?url=${encodeURIComponent(url)}&screenshot=true&meta=false&embed=screenshot.url&viewport.width=1365&viewport.height=860`;
---

<section id="projects" class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-sm uppercase letter-spacing-wide font-medium mb-16 reveal" style="color: var(--text-muted);">Featured work</h2>

    {projects.map((project, i) => {
      const imageOnLeft = i % 2 === 0;
      return (
        <div class="mb-24 reveal" style={`animation-delay: ${i * 0.1}s`}>
          <div class="project-grid items-center">
            <div class={`project-image rounded-lg overflow-hidden border${imageOnLeft ? '' : ' md-order-2'}`} style="aspect-ratio: 1365/860; background-color: var(--border-subtle); border-color: var(--border);">
              {project.url && (
                <img src={screenshotUrl(project.url)} alt={project.title} class="w-full h-full object-contain" style="background-color: var(--border-subtle);" loading="lazy" />
              )}
            </div>
            <div class={`project-text${imageOnLeft ? '' : ' md-order-1'}`}>
              <p class="text-xs uppercase letter-spacing-wide mb-3 font-medium" style="color: var(--text-muted);">{project.type}</p>
              <h3 class="text-3xl font-bold mb-4" style="color: var(--text);">{project.title}</h3>
              <p class="leading-relaxed mb-6" style="color: var(--text-muted);">{project.summary}</p>
              {project.url && (
                <a href={project.url} target="_blank" rel="noopener noreferrer" class="font-medium" style="color: var(--accent);" onmouseover="this.style.color='var(--hover-accent)'" onmouseout="this.style.color='var(--accent)'">
                  View live →
                </a>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .letter-spacing-wide {
    letter-spacing: 0.1em;
  }

  .project-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  /* On mobile: image always first */
  .project-image { order: 1; }
  .project-text  { order: 2; }

  @media (min-width: 768px) {
    .project-grid {
      grid-template-columns: 1fr 1.1fr;
      gap: 5rem;
    }
    /* Restore desktop order for alternating layout */
    .md-order-1 { order: 1; }
    .md-order-2 { order: 2; }
  }
</style>
