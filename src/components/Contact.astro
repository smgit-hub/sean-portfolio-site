---
---

<section id="contact" class="section-padding relative overflow-hidden">
  <!-- Background -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at 50% 100%, rgba(0,255,136,0.05), transparent 60%);"
  ></div>

  <div class="max-w-6xl mx-auto px-6">
    <!-- Label -->
    <div class="flex items-center gap-3 mb-4 reveal">
      <span class="font-mono text-neon-green/60 text-xs tracking-widest uppercase">06 / Contact</span>
      <span class="flex-1 max-w-[60px] h-px bg-neon-green/20"></span>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: text -->
      <div>
        <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-6 reveal">
          Let's build<br />
          <span class="gradient-text-green-blue">something together</span>
        </h2>

        <div class="space-y-4 text-white/50 mb-10 reveal reveal-delay-1">
          <p>
            Whether you're looking for a developer to help ship a project, build a new site from scratch, or collaborate on something interesting — I'd like to hear about it.
          </p>
          <p>
            I'm open to freelance work, full-time opportunities, internships, and interesting collaborations. Don't hesitate to reach out.
          </p>
        </div>

      </div>

      <!-- Right: contact form -->
      <div class="reveal reveal-delay-2">
        <form
          id="contact-form"
          name="contact"
          action="/thank-you"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="glass rounded-2xl p-7 border border-white/5 space-y-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden" aria-hidden="true">
            <label>
              Don't fill this out
              <input name="bot-field" tabindex="-1" autocomplete="off" />
            </label>
          </p>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs text-white/40 font-mono mb-2" for="name">Name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                minlength="2"
                maxlength="80"
                pattern="[A-Za-z][A-Za-z\s'\-]{1,79}"
                placeholder="Your name"
                class="w-full bg-white/[0.03] border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/25 focus:outline-none focus:border-neon-green/40 focus:shadow-glow-sm-green transition-all duration-300"
              />
            </div>
            <div>
              <label class="block text-xs text-white/40 font-mono mb-2" for="email">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                maxlength="120"
                placeholder="your@email.com"
                class="w-full bg-white/[0.03] border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/25 focus:outline-none focus:border-neon-green/40 focus:shadow-glow-sm-green transition-all duration-300"
              />
            </div>
          </div>

          <div>
            <label class="block text-xs text-white/40 font-mono mb-2" for="subject">Subject</label>
            <input
              id="subject"
              name="subject"
              type="text"
              minlength="3"
              maxlength="100"
              placeholder="What's this about?"
              class="w-full bg-white/[0.03] border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/25 focus:outline-none focus:border-neon-green/40 focus:shadow-glow-sm-green transition-all duration-300"
            />
          </div>

          <div>
            <label class="block text-xs text-white/40 font-mono mb-2" for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              minlength="20"
              maxlength="1500"
              placeholder="Tell me about your project..."
              class="w-full bg-white/[0.03] border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/25 focus:outline-none focus:border-neon-green/40 focus:shadow-glow-sm-green transition-all duration-300 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-neon-green text-black font-semibold text-sm transition-all duration-300 hover:shadow-glow-green hover:scale-[1.02] active:scale-[0.98] disabled:opacity-70 disabled:cursor-not-allowed disabled:hover:scale-100"
            data-submit-button
          >
            <span data-submit-label>Send message</span>
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
            </svg>
          </button>

          <p class="text-xs text-white/40 text-center font-mono min-h-[1rem]" data-form-status aria-live="polite"></p>

          <p class="text-xs text-white/25 text-center font-mono">Spam honeypot enabled.</p>
        </form>

        <div
          class="glass rounded-2xl p-7 border border-white/5 hidden"
          data-contact-success
        >
          <p class="font-mono text-neon-green/70 text-xs tracking-widest uppercase mb-3">Message Sent</p>
          <h3 class="font-display text-3xl font-bold mb-3">Thank you</h3>
          <p class="text-white/55 leading-relaxed mb-6">
            Your message has been received. I will get back to you as soon as possible.
          </p>
          <a
            href="#projects"
            data-success-cta
            class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-neon-green text-black font-semibold text-sm transition-all duration-300 hover:shadow-glow-green hover:scale-[1.02]"
          >
            View my work
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const contactForm = document.querySelector('#contact-form');
  const successPanel = document.querySelector('[data-contact-success]');
  const successCta = document.querySelector('[data-success-cta]');

  if (contactForm instanceof HTMLFormElement) {
    const submitButton = contactForm.querySelector('[data-submit-button]');
    const submitLabel = contactForm.querySelector('[data-submit-label]');
    const statusText = contactForm.querySelector('[data-form-status]');
    const defaultLabel = submitLabel instanceof HTMLElement ? submitLabel.textContent : 'Send message';

    const setStatus = (message, tone = 'neutral') => {
      if (!(statusText instanceof HTMLElement)) return;
      statusText.textContent = message;

      statusText.classList.remove('text-white/40', 'text-neon-green/80', 'text-red-300');
      if (tone === 'success') statusText.classList.add('text-neon-green/80');
      if (tone === 'error') statusText.classList.add('text-red-300');
      if (tone === 'neutral') statusText.classList.add('text-white/40');
    };

    const isValidEmail = (value) => /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/i.test(value);
    const readField = (name) => {
      const field = contactForm.elements.namedItem(name);
      if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
        return field.value.trim();
      }
      return '';
    };

    const setSubmittingState = (isSubmitting) => {
      if (!(submitButton instanceof HTMLButtonElement) || !(submitLabel instanceof HTMLElement)) {
        return;
      }
      submitButton.disabled = isSubmitting;
      submitLabel.textContent = isSubmitting ? 'Sending...' : defaultLabel;
    };

    const showSuccessPanel = () => {
      if (!(submitLabel instanceof HTMLElement)) return;
      setStatus('Message sent successfully.', 'success');
      contactForm.reset();
      submitLabel.textContent = 'Sent';

      if (successPanel instanceof HTMLElement) {
        contactForm.classList.add('hidden');
        successPanel.classList.remove('hidden');
      }
    };

    const resetAfterSuccess = () => {
      if (!(submitButton instanceof HTMLButtonElement) || !(submitLabel instanceof HTMLElement)) {
        return;
      }
      contactForm.reset();
      contactForm.classList.remove('hidden');
      if (successPanel instanceof HTMLElement) successPanel.classList.add('hidden');
      submitButton.disabled = false;
      submitLabel.textContent = defaultLabel;
      setStatus('', 'neutral');
    };

    const encodeForm = () => {
      const encoded = new URLSearchParams();
      for (const [key, value] of new FormData(contactForm).entries()) {
        if (typeof value === 'string') encoded.append(key, value.trim());
      }
      return encoded.toString();
    };

    const validateForm = () => {
      const nameValue = readField('name');
      const emailValue = readField('email');
      const subjectValue = readField('subject');
      const messageValue = readField('message');
      const botFieldValue = readField('bot-field');

      if (botFieldValue) return false;
      if (nameValue.length < 2) {
        setStatus('Please enter your full name.', 'error');
        return false;
      }
      if (!isValidEmail(emailValue)) {
        setStatus('Please enter a valid email address.', 'error');
        return false;
      }
      if (subjectValue.length > 0 && subjectValue.length < 3) {
        setStatus('Subject should be at least 3 characters.', 'error');
        return false;
      }
      if (messageValue.length < 20) {
        setStatus('Message should be at least 20 characters.', 'error');
        return false;
      }
      return true;
    };

    contactForm.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!(submitButton instanceof HTMLButtonElement)) return;
      if (submitButton.disabled) return;
      if (!(submitLabel instanceof HTMLElement)) return;
      if (!contactForm.checkValidity()) {
        contactForm.reportValidity();
        return;
      }
      if (!validateForm()) return;

      setSubmittingState(true);
      setStatus('Submitting your message...', 'neutral');

      try {
        const response = await fetch('/', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: encodeForm(),
        });

        if (!response.ok) {
          throw new Error(`Unexpected status: ${response.status}`);
        }

        showSuccessPanel();
      } catch {
        setSubmittingState(false);
        setStatus('Could not send right now. Please try again in a moment.', 'error');
      }
    });

    if (successCta instanceof HTMLAnchorElement) {
      successCta.addEventListener('click', resetAfterSuccess);
    }
  }
</script>
