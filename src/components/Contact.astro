<section id="contact" class="py-16 border-t" style="border-color: var(--border);">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-2xl">
    <h2 class="text-3xl font-bold mb-8 reveal" style="color: var(--text);">Get in touch</h2>
    <p class="text-lg mb-8 reveal reveal-delay-1" style="color: var(--text-muted);">Have a project or idea? I'm available for freelance work or full-time opportunities.</p>
    <a href="mailto:hello@sean.dev" class="inline-block px-6 py-3 border font-medium rounded transition-colors reveal reveal-delay-2" style="border-color: var(--accent); color: var(--accent);" onmouseover="this.style.backgroundColor='rgba(34, 197, 94, 0.1)'" onmouseout="this.style.backgroundColor='transparent'">
      Email me
    </a>
    </div>
  </div>
</section>
