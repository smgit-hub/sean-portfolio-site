---
const links = [
  {
    label: 'GitHub',
    value: 'github.com/smgit-hub',
    href:  'https://github.com/smgit-hub',
    icon: `<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    value: 'www.linkedin.com/in/sean-millard-61bb61366',
    href:  'https://www.linkedin.com/in/sean-millard-61bb61366',
    icon: `<svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
];

---

<section id="contact" class="section-padding relative overflow-hidden">
  <!-- Background -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at 50% 100%, rgba(0,255,136,0.05), transparent 60%);"
  ></div>

  <div class="max-w-6xl mx-auto px-6">
    <!-- Label -->
    <div class="flex items-center gap-3 mb-4 reveal">
      <span class="font-mono text-neon-green/60 text-xs tracking-widest uppercase">06 / Contact</span>
      <span class="flex-1 max-w-[60px] h-px bg-neon-green/20"></span>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: text + social links -->
      <div>
        <h2 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-6 reveal">
          Let's build<br />
          <span class="gradient-text-green-blue">something together</span>
        </h2>

        <div class="space-y-4 text-white/50 mb-10 reveal reveal-delay-1">
          <p>
            Whether you're looking for a developer to help ship a project, build a new site from scratch, or collaborate on something interesting — I'd like to hear about it.
          </p>
          <p>
            I'm open to freelance work, full-time opportunities, internships, and interesting collaborations. Don't hesitate to reach out.
          </p>
        </div>

        <!-- Social links -->
        <div class="space-y-3 reveal reveal-delay-2">
          {links.map((link) => {
            return (
              <a
                href={link.href}
                target={link.label !== 'Email' ? '_blank' : undefined}
                rel={link.label !== 'Email' ? 'noopener noreferrer' : undefined}
                class="flex items-center gap-4 group glass glass-hover rounded-xl px-5 py-4 border border-white/5"
              >
                <span class="text-white/40 group-hover:text-white/80 transition-colors duration-300" set:html={link.icon}></span>
                <div class="flex-1">
                  <p class="text-xs text-white/30 font-mono mb-0.5">{link.label}</p>
                  <p class="text-sm text-white/60 group-hover:text-white/80 transition-colors duration-300">{link.value}</p>
                </div>
                <svg
                  width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"
                  class="text-white/20 group-hover:text-white/60 transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                >
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </a>
            );
          })}
        </div>
      </div>

      <!-- Right: contact form -->
      <div class="reveal reveal-delay-2">
        <form
          id="contact-form"
          name="contact"
          action="/thank-you"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="glass rounded-2xl p-7 border border-white/5 space-y-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <input type="hidden" name="subject" value="New portfolio contact form submission" />
          <p class="hidden" aria-hidden="true">
            <label>
              Don't fill this out
              <input name="bot-field" tabindex="-1" autocomplete="off" />
            </label>
          </p>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs text-white/40 font-mono mb-2" for="name">Name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Your name"
                class="w-full bg-white/[0.03] border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/25 focus:outline-none focus:border-neon-green/40 focus:shadow-glow-sm-green transition-all duration-300"
              />
            </div>
            <div>
              <label class="block text-xs text-white/40 font-mono mb-2" for="email">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="your@email.com"
                class="w-full bg-white/[0.03] border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/25 focus:outline-none focus:border-neon-green/40 focus:shadow-glow-sm-green transition-all duration-300"
              />
            </div>
          </div>

          <div>
            <label class="block text-xs text-white/40 font-mono mb-2" for="subject">Subject</label>
            <input
              id="subject"
              name="subject"
              type="text"
              placeholder="What's this about?"
              class="w-full bg-white/[0.03] border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/25 focus:outline-none focus:border-neon-green/40 focus:shadow-glow-sm-green transition-all duration-300"
            />
          </div>

          <div>
            <label class="block text-xs text-white/40 font-mono mb-2" for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              placeholder="Tell me about your project..."
              class="w-full bg-white/[0.03] border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder-white/25 focus:outline-none focus:border-neon-green/40 focus:shadow-glow-sm-green transition-all duration-300 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full flex items-center justify-center gap-2 px-6 py-3.5 rounded-full bg-neon-green text-black font-semibold text-sm transition-all duration-300 hover:shadow-glow-green hover:scale-[1.02] active:scale-[0.98]"
          >
            Send message
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
            </svg>
          </button>

          <p class="text-xs text-white/25 text-center font-mono">
            // Contact form enabled with spam honeypot protection.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
