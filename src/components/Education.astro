---
const timeline = [
  {
    credential: 'Level Design',
    specialisation: 'Custom Furniture Design & Manufacture · 2016 — Present',
    institution: 'Self-employed · Melbourne',
    status: 'ongoing',
    highlights: [
      'Designed and built bespoke timber dining tables for private clients, architects, and interior designers',
      'Worked in traditional joinery using sustainably sourced American and Australian hardwoods',
      'Featured in Belle and Houzz for heirloom-quality, made-to-last design work',
      'Built a design-first process that now carries directly into how I approach web development',
    ],
  },
  {
    credential: 'Certificate IV in Information Technology',
    specialisation: 'Web Development',
    institution: 'Holmesglen TAFE',
    status: 'completed',
    highlights: [
      'Built foundational skills in HTML, CSS, and JavaScript',
      'Introduced to responsive design and web standards',
      'Delivered multiple assessed projects to industry-standard briefs',
      'Gained exposure to CMS platforms, basic databases, and deployment',
    ],
  },
  {
    credential: 'Diploma of Information Technology',
    specialisation: 'Back End Web Development',
    institution: 'Lumify Learn',
    status: 'completed',
    highlights: [
      'Deepened server-side development skills including databases and APIs',
      'Applied back-end knowledge to real projects built alongside study',
      'Expanded from front-end competence into full-stack capability',
      'Developed professional workflows with version control and deployment pipelines',
    ],
  },
];

const statusLabels = {
  completed: 'Completed',
  ongoing: 'Ongoing',
} as const;
---

<section id="education" class="section-padding relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Label -->
    <div class="flex items-center gap-3 mb-4 reveal">
      <span class="section-label font-mono text-xs tracking-widest uppercase">Education</span>
      <span class="section-label-line flex-1 max-w-[60px] h-px"></span>
    </div>

    <h2 class="text-3xl font-bold mb-4 reveal" style="color: var(--text);">
      Learning with <span style="color: var(--accent);">purpose</span>
    </h2>
    <p class="text-lg max-w-xl mb-14 reveal reveal-delay-1" style="color: var(--text-muted);">
      Formal study has given me structure, but the real education has come from building — and doing both at the same time.
    </p>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="hidden md:block absolute left-6 top-0 bottom-0 w-px pointer-events-none bg-white/10"></div>

      <div class="space-y-8">
        {timeline.map((item, i) => {
          const statusLabel = statusLabels[item.status];
          const dotColor = item.status === 'ongoing' ? 'var(--accent)' : 'var(--text-muted)';
          return (
            <div class={`reveal reveal-delay-${i + 1} relative md:pl-20`}>
            <!-- Timeline dot -->
            <div
              class="hidden md:flex absolute left-0 top-6 w-12 h-12 rounded-full border items-center justify-center"
              style={`border-color: ${dotColor}; background-color: var(--bg);`}
            >
              {item.status === 'completed' ? (
                <svg width="16" height="16" fill="none" stroke={dotColor} stroke-width="2.5" viewBox="0 0 24 24">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              ) : (
                <span class="w-2 h-2 rounded-full inline-block" style={`background: ${dotColor};`}></span>
              )}
            </div>

            <!-- Card -->
            <div
              class="rounded-lg p-6 border group"
              style={`border-color: var(--border); background-color: var(--bg);`}
            >
              <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                <div>
                  <p class="text-xs font-mono mb-1" style="color: var(--text-muted);">{item.institution}</p>
                  <h3 class="text-xl font-semibold leading-snug" style="color: var(--text);">
                    {item.credential}
                  </h3>
                  <p class="text-sm mt-0.5" style="color: var(--text-muted);">{item.specialisation}</p>
                </div>
                <span
                  class="flex-shrink-0 text-xs font-mono px-3 py-1 rounded-full border"
                  style={`
                    color: ${item.status === 'ongoing' ? 'var(--accent)' : 'var(--text-muted)'};
                    border-color: var(--border);
                    background-color: var(--bg);
                  `}
                >
                  {statusLabel}
                </span>
              </div>

              <ul class="space-y-2">
                {item.highlights.map((point) => (
                  <li class="flex items-start gap-3 text-sm" style="color: var(--text-muted);">
                    <span
                      class="mt-1.5 w-1 h-1 rounded-full flex-shrink-0"
                      style={`background: ${item.status === 'ongoing' ? 'var(--accent)' : 'var(--text-muted)'};`}
                    ></span>
                    {point}
                  </li>
                ))}
              </ul>
            </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
