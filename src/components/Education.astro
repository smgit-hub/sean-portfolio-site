---
const timeline = [
  {
    credential: 'Certificate IV in Information Technology',
    specialisation: 'Web Development',
    institution: 'Holmesglen TAFE',
    status: 'completed',
    highlights: [
      'Built foundational skills in HTML, CSS, and JavaScript',
      'Introduced to responsive design and web standards',
      'Delivered multiple assessed projects to industry-standard briefs',
      'Gained exposure to CMS platforms, basic databases, and deployment',
    ],
  },
  {
    credential: 'Diploma of Information Technology',
    specialisation: 'Back End Web Development',
    institution: 'Lumify Learn',
    status: 'in-progress',
    highlights: [
      'Deepening server-side development skills including databases and APIs',
      'Applying back-end knowledge to real projects built alongside study',
      'Expanding from front-end competence into full-stack capability',
      'Developing professional workflows with version control and deployment pipelines',
    ],
  },
];

const statusStyles = {
  completed: {
    border: 'rgba(0,255,136,0.3)',
    text: '#00ff88',
    chipBorder: 'rgba(0,255,136,0.2)',
    chipBg: 'rgba(0,255,136,0.05)',
  },
  'in-progress': {
    border: 'rgba(0,180,255,0.3)',
    text: '#00b4ff',
    chipBorder: 'rgba(0,180,255,0.2)',
    chipBg: 'rgba(0,180,255,0.05)',
  },
} as const;
---

<section id="education" class="section-padding relative overflow-hidden">
  <div
    class="absolute top-0 left-1/3 w-[400px] h-[400px] pointer-events-none"
    style="background: radial-gradient(circle at 50% 0%, rgba(0,255,136,0.04), transparent 60%);"
  ></div>

  <div class="max-w-7xl mx-auto px-6">
    <!-- Label -->
    <div class="flex items-center gap-3 mb-4 reveal">
      <span class="font-mono text-neon-green/60 text-xs tracking-widest uppercase">04 / Education</span>
      <span class="flex-1 max-w-[60px] h-px bg-neon-green/20"></span>
    </div>

    <h2 class="font-display text-4xl md:text-5xl font-bold mb-4 reveal">
      Learning with <span class="gradient-text-green-blue">purpose</span>
    </h2>
    <p class="text-white/45 max-w-xl mb-14 reveal reveal-delay-1">
      Formal study has given me structure, but the real education has come from building — and doing both at the same time.
    </p>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="hidden md:block absolute left-6 top-0 bottom-0 w-px bg-gradient-to-b from-neon-green/30 via-neon-blue/20 to-transparent"></div>

      <div class="space-y-8">
        {timeline.map((item, i) => {
          const statusStyle = statusStyles[item.status];
          const statusLabel = item.status === 'completed' ? 'Completed' : 'In Progress';
          return (
            <div class={`reveal reveal-delay-${i + 1} relative md:pl-20`}>
            <!-- Timeline dot -->
            <div
              class="hidden md:flex absolute left-0 top-6 w-12 h-12 rounded-full glass border items-center justify-center"
              style={`border-color: ${statusStyle.border};`}
            >
              {item.status === 'completed' ? (
                <svg width="16" height="16" fill="none" stroke="#00ff88" stroke-width="2.5" viewBox="0 0 24 24">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              ) : (
                <span class="w-2 h-2 rounded-full bg-neon-blue animate-glow-pulse inline-block"></span>
              )}
            </div>

            <!-- Card -->
            <div
              class="glass glass-hover rounded-2xl p-7 border group"
              style={`border-color: rgba(255,255,255,0.05);`}
            >
              <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                <div>
                  <p class="font-mono text-xs text-white/35 mb-1">{item.institution}</p>
                  <h3 class="font-display font-semibold text-xl text-white leading-snug">
                    {item.credential}
                  </h3>
                  <p class="text-sm text-white/50 mt-0.5">{item.specialisation}</p>
                </div>
                <span
                  class="flex-shrink-0 text-xs font-mono px-3 py-1 rounded-full border"
                  style={`
                    color: ${statusStyle.text};
                    border-color: ${statusStyle.chipBorder};
                    background: ${statusStyle.chipBg};
                  `}
                >
                  {statusLabel}
                </span>
              </div>

              <ul class="space-y-2">
                {item.highlights.map((point) => (
                  <li class="flex items-start gap-3 text-sm text-white/45">
                    <span
                      class="mt-1.5 w-1 h-1 rounded-full flex-shrink-0"
                      style={`background: ${statusStyle.text}; opacity: 0.6;`}
                    ></span>
                    {point}
                  </li>
                ))}
              </ul>
            </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
